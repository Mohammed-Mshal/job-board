        "hero": {
            "subtitle": "About Jobify",
            "title": "Building the future of",
            "title-highlight": "modern hiring",
            "description": "Jobify connects ambitious professionals with companies that value talent, growth, and meaningful work. We make hiring clearer, faster, and more human."
        },
        "mission": {
            "mission-title": "Our Mission",
            "mission-description": "To empower people and companies to find the right match through a transparent, intelligent, and accessible hiring platform.",
